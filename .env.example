# Runtime
NODE_ENV=development
PORT=5001

# Supabase / Database
# Use the base project URL, not the /rest/v1/ endpoint.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://user:password@host:5432/database
SUPABASE_DB_URL=postgresql://user:password@host:5432/database

# Frontend Supabase client
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# GitHub integration / deploy helpers
GITHUB_URL=https://github.com/owner/repository.git
GITHUB_TOKEN=ghp_your-token

# OpenAI translations
OPENAI_API_KEY=sk-your-openai-key

# Email / Resend
RESEND_API_KEY=re_your-resend-key
RESEND_SENDER_DOMAIN=resend.dev
EVENT_REQUEST_EMAIL=info@cameraconvista.it

# Analytics, optional
VITE_GA_MEASUREMENT_ID=
VITE_FB_PIXEL_ID=

# Playwright, optional
PLAYWRIGHT_BASE_URL=http://127.0.0.1:5001
